{
  "_meta": "antigravity(Gemini language_server) 固定内置工具集。schema 由 transcript 里真实 tool_call 的参数键统计反推（OpenAI tools 形态），非官方定义；toolAction/toolSummary 为 antigravity 内部 UI 元字段，统一记为可选 metadata。来源脚本注释见 antigravity_transcript_adapter.py。",
  "tools": [
    {"type": "function", "function": {"name": "run_command", "description": "在 shell 里执行命令。", "parameters": {"type": "object", "properties": {"CommandLine": {"type": "string"}, "Cwd": {"type": "string"}, "WaitMsBeforeAsync": {"type": "integer"}}, "required": ["CommandLine", "Cwd"]}}},
    {"type": "function", "function": {"name": "view_file", "description": "读文件内容，可选行区间。", "parameters": {"type": "object", "properties": {"AbsolutePath": {"type": "string"}, "StartLine": {"type": "integer"}, "EndLine": {"type": "integer"}, "IsSkillFile": {"type": "boolean"}}, "required": ["AbsolutePath"]}}},
    {"type": "function", "function": {"name": "list_dir", "description": "列目录内容。", "parameters": {"type": "object", "properties": {"DirectoryPath": {"type": "string"}}, "required": ["DirectoryPath"]}}},
    {"type": "function", "function": {"name": "grep_search", "description": "按正文/正则搜代码。", "parameters": {"type": "object", "properties": {"Query": {"type": "string"}, "SearchPath": {"type": "string"}, "MatchPerLine": {"type": "boolean"}, "CaseInsensitive": {"type": "boolean"}, "IsRegex": {"type": "boolean"}, "Includes": {"type": "array", "items": {"type": "string"}}}, "required": ["Query", "SearchPath"]}}},
    {"type": "function", "function": {"name": "write_to_file", "description": "新建/覆写文件。", "parameters": {"type": "object", "properties": {"TargetFile": {"type": "string"}, "CodeContent": {"type": "string"}, "Description": {"type": "string"}, "Overwrite": {"type": "boolean"}, "IsArtifact": {"type": "boolean"}, "ArtifactMetadata": {"type": "object"}}, "required": ["TargetFile", "CodeContent"]}}},
    {"type": "function", "function": {"name": "replace_file_content", "description": "按 TargetContent→ReplacementContent 精确替换文件片段。", "parameters": {"type": "object", "properties": {"TargetFile": {"type": "string"}, "TargetContent": {"type": "string"}, "ReplacementContent": {"type": "string"}, "Instruction": {"type": "string"}, "Description": {"type": "string"}, "StartLine": {"type": "integer"}, "EndLine": {"type": "integer"}, "AllowMultiple": {"type": "boolean"}}, "required": ["TargetFile", "TargetContent", "ReplacementContent"]}}},
    {"type": "function", "function": {"name": "multi_replace_file_content", "description": "一次对一个文件做多处替换。", "parameters": {"type": "object", "properties": {"TargetFile": {"type": "string"}, "ReplacementChunks": {"type": "array", "items": {"type": "object"}}, "Instruction": {"type": "string"}, "Description": {"type": "string"}}, "required": ["TargetFile", "ReplacementChunks"]}}},
    {"type": "function", "function": {"name": "search_web", "description": "联网搜索。", "parameters": {"type": "object", "properties": {"query": {"type": "string"}}, "required": ["query"]}}},
    {"type": "function", "function": {"name": "read_url_content", "description": "抓取 URL 正文。", "parameters": {"type": "object", "properties": {"Url": {"type": "string"}}, "required": ["Url"]}}},
    {"type": "function", "function": {"name": "manage_task", "description": "任务清单增删改。", "parameters": {"type": "object", "properties": {"Action": {"type": "string"}, "TaskId": {"type": "string"}}, "required": ["Action"]}}},
    {"type": "function", "function": {"name": "manage_subagents", "description": "子代理管理。", "parameters": {"type": "object", "properties": {"Action": {"type": "string"}}, "required": ["Action"]}}},
    {"type": "function", "function": {"name": "schedule", "description": "定时唤醒/延时任务。", "parameters": {"type": "object", "properties": {"DurationSeconds": {"type": "integer"}, "Prompt": {"type": "string"}}, "required": ["DurationSeconds", "Prompt"]}}},
    {"type": "function", "function": {"name": "send_message", "description": "向指定接收方发消息。", "parameters": {"type": "object", "properties": {"Message": {"type": "string"}, "Recipient": {"type": "string"}}, "required": ["Message", "Recipient"]}}},
    {"type": "function", "function": {"name": "list_permissions", "description": "列出当前权限。", "parameters": {"type": "object", "properties": {}}}},
    {"type": "function", "function": {"name": "ask_permission", "description": "请求执行某动作的权限。", "parameters": {"type": "object", "properties": {"Action": {"type": "string"}, "Target": {"type": "string"}, "Reason": {"type": "string"}}, "required": ["Action"]}}}
  ],
  "_ui_meta_args": ["toolAction", "toolSummary"]
}
